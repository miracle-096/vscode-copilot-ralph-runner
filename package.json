{
  "name": "harness-runner",
  "displayName": "Harness Runner",
  "description": "Autonomous task runner — reads prd.json user stories, tracks progress inline, and drives Copilot Chat to execute each story in an auditable execution loop",
  "version": "0.0.9",
  "publisher": "recent-graduates",
  "repository": {
    "type": "git",
    "url": "https://github.com/anushibinj/vscode-copilot-ralph-runner.git"
  },
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onChatParticipant:recent-graduates.harness-runner"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "harness-runner.showIntroduction",
        "title": "HARNESS: 插件介绍"
      },
      {
        "command": "harness-runner.showUsageGuide",
        "title": "HARNESS: 使用流程手册"
      },
      {
        "command": "harness-runner.configurePolicyGates",
        "title": "HARNESS: 配置执行检查"
      },
      {
        "command": "harness-runner.start",
        "title": "HARNESS: 开始执行"
      },
      {
        "command": "harness-runner.rerunFailedStory",
        "title": "HARNESS: 重新执行失败故事"
      },
      {
        "command": "harness-runner.stop",
        "title": "HARNESS: 停止执行"
      },
      {
        "command": "harness-runner.status",
        "title": "HARNESS: 查看状态"
      },
      {
        "command": "harness-runner.reviewStoryApproval",
        "title": "HARNESS: 审批故事"
      },
      {
        "command": "harness-runner.resetStep",
        "title": "HARNESS: 重置故事"
      },
      {
        "command": "harness-runner.initProjectConstraints",
        "title": "HARNESS: 初始化项目约束"
      },
      {
        "command": "harness-runner.refreshSourceContextIndex",
        "title": "HARNESS: 刷新源码上下文索引"
      },
      {
        "command": "harness-runner.previewSourceContextRecall",
        "title": "HARNESS: 为故事添加上下文"
      },
      {
        "command": "harness-runner.generateAgentMap",
        "title": "HARNESS: 生成 Agent Map"
      },
      {
        "command": "harness-runner.recordDesignContext",
        "title": "HARNESS: 界面设计描述"
      },
      {
        "command": "harness-runner.openSettings",
        "title": "HARNESS: 打开设置"
      },
      {
        "command": "harness-runner.customizeMenuOrder",
        "title": "HARNESS: 自定义菜单排序"
      },
      {
        "command": "harness-runner.showMenu",
        "title": "HARNESS: 显示菜单"
      },
      {
        "command": "harness-runner.quickStart",
        "title": "HARNESS: 生成 PRD"
      },
      {
        "command": "harness-runner.appendUserStories",
        "title": "HARNESS: 追加用户故事"
      }
    ],
    "keybindings": [
      {
        "command": "harness-runner.showMenu",
        "key": "alt+r"
      }
    ],
    "chatParticipants": [
      {
        "id": "recent-graduates.harness-runner",
        "name": "harness",
        "fullName": "Harness Runner",
        "description": "Refine a change request against Harness Runner project constraints, then auto-send the final prompt to Copilot Chat.",
        "isSticky": true,
        "commands": [
          {
            "name": "harness-spec",
            "description": "Polish a request with the merged Harness Runner project constraints, then auto-send the ready-to-use final version to Copilot Chat."
          }
        ]
      }
    ],
    "configuration": {
      "title": "Harness Runner",
      "properties": {
        "harness-runner.maxAutonomousLoops": {
          "type": "number",
          "default": 2,
          "minimum": 1,
          "description": "每次运行在暂停前最多连续执行的故事数量。"
        },
        "harness-runner.loopDelayMs": {
          "type": "number",
          "default": 3000,
          "minimum": 0,
          "description": "每轮执行之间的等待时间，单位为毫秒。"
        },
        "harness-runner.copilotResponsePollMs": {
          "type": "number",
          "default": 5000,
          "minimum": 1000,
          "description": "轮询 Copilot 是否空闲的间隔时间，单位为毫秒。"
        },
        "harness-runner.copilotTimeoutMs": {
          "type": "number",
          "default": 3600000,
          "minimum": 30000,
          "description": "每个故事等待 Copilot 完成的最长时间，单位为毫秒，默认 1 小时。"
        },
        "harness-runner.copilotMinWaitMs": {
          "type": "number",
          "default": 15000,
          "minimum": 0,
          "description": "开始检查故事是否完成前，至少等待 Copilot 开始工作的时间，单位为毫秒。"
        },
        "harness-runner.autoInjectProjectConstraints": {
          "type": "boolean",
          "default": true,
          "description": "启用后，在构建任务提示词时自动注入已初始化的项目约束。"
        },
        "harness-runner.autoInjectDesignContext": {
          "type": "boolean",
          "default": true,
          "description": "启用后，在构建任务提示词时自动注入已记录的界面设计描述。"
        },
        "harness-runner.autoRecallTaskMemory": {
          "type": "boolean",
          "default": true,
          "description": "启用后，在执行故事前自动回忆相关任务记忆，并注入有限长度的既往工作上下文。"
        },
        "harness-runner.autoCommitGit": {
          "type": "boolean",
          "default": true,
          "description": "启用后，若工作区检测到 Git 仓库，Harness Runner 会在执行单个用户故事时要求 Copilot 直接完成对应的 Git 提交，而不是额外生成单独的 Git 提交故事。"
        },
        "harness-runner.recalledTaskMemoryLimit": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "maximum": 10,
          "description": "每个故事最多注入或预览的相关任务记忆条目数量。"
        },
        "harness-runner.policyGates": {
          "type": "object",
          "default": {
            "enabled": false,
            "preflightRules": [
              {
                "id": "require-project-constraints",
                "title": "Require project rules before start",
                "phase": "preflight",
                "type": "required-artifact",
                "artifact": "project-constraints",
                "enabled": false,
                "when": "always"
              },
              {
                "id": "require-design-context",
                "title": "Require design notes for UI-sensitive stories",
                "phase": "preflight",
                "type": "required-artifact",
                "artifact": "design-context",
                "enabled": false,
                "when": "story.designSensitive"
              }
            ],
            "completionRules": [
              {
                "id": "protect-dangerous-paths",
                "title": "Block risky file changes",
                "phase": "completion",
                "type": "restricted-paths",
                "paths": [
                  "prd.json",
                  ".prd/**",
                  "dist/**",
                  "build/**",
                  "out/**",
                  "coverage/**",
                  "node_modules/**",
                  ".next/**",
                  ".nuxt/**"
                ],
                "enabled": true,
                "when": "always"
              },
              {
                "id": "require-relevant-tests",
                "title": "Require at least one relevant test",
                "phase": "completion",
                "type": "require-command",
                "commandsFrom": "projectConstraints.testCommands",
                "minSuccesses": 1,
                "filePatterns": [
                  "src/**",
                  "package.json",
                  "eslint.config.*",
                  "tsconfig.json"
                ],
                "enabled": false,
                "when": "always"
              },
              {
                "id": "require-fresh-knowledge",
                "title": "Require fresh knowledge coverage before completion",
                "phase": "completion",
                "type": "knowledge-check",
                "failOnSeverities": [
                  "warning"
                ],
                "enabled": false,
                "when": "always"
              },
              {
                "id": "require-task-memory-artifact",
                "title": "Require task memory before completion",
                "phase": "completion",
                "type": "required-artifact",
                "artifact": "task-memory",
                "enabled": true,
                "when": "always"
              },
              {
                "id": "require-execution-checkpoint-artifact",
                "title": "Require execution checkpoint before completion",
                "phase": "completion",
                "type": "required-artifact",
                "artifact": "execution-checkpoint",
                "enabled": true,
                "when": "always"
              },
              {
                "id": "require-story-evidence-artifact",
                "title": "Require story evidence before completion",
                "phase": "completion",
                "type": "required-artifact",
                "artifact": "story-evidence",
                "enabled": true,
                "when": "always"
              }
            ]
          },
          "markdownDescription": "自动检查规则。开启后，Harness Runner 会在故事开始前和完成前按这里的 preflight/completion 规则检查；其中 `knowledge-check` 可把 Agent Map 新鲜度、模块知识缺口和运行说明覆盖缺口作为 advisory 或 gate 使用。旧的 `requireProjectConstraintsBeforeRun` 和 `requireDesignContextForTaggedStories` 仍会兼容读取，但不再单独展示。"
        },
        "harness-runner.policyGateCommandTimeoutMs": {
          "type": "number",
          "default": 600000,
          "minimum": 1000,
          "description": "自动检查在执行测试或构建命令时的超时时间，单位为毫秒。"
        },
        "harness-runner.approvalPromptMode": {
          "type": "string",
          "default": "default",
          "enum": ["default", "bypass", "autopilot"],
          "enumDescriptions": [
            "当前工作区若存在覆盖则优先使用；否则回退到 User 全局设置。高风险故事完成后显示审批提示，可选择打开审批流或证据包。",
            "当前工作区若存在覆盖则优先使用；否则回退到 User 全局设置。高风险故事完成后直接进入审批流，跳过中间提示。",
            "当前工作区若存在覆盖则优先使用；否则回退到 User 全局设置。高风险故事完成后不依赖弹窗，而是通过日志、状态栏和菜单持续提示待审批故事。"
          ],
          "description": "审批提示模式。Harness Runner 按“工作区覆盖优先、否则回退到 User 全局设置”的顺序读取该值，并在新开 Copilot Chat 时继续按该模式处理审批交互。"
        },
        "harness-runner.enableReviewerLoop": {
          "type": "boolean",
          "default": true,
          "description": "是否启用 Reviewer 评分流程。Harness Runner 按“工作区覆盖优先、否则回退到 User 全局设置”的顺序读取该值；关闭后，故事执行完成后不再进入 Reviewer pass 和自动修复回路。"
        },
        "harness-runner.reviewPassingScore": {
          "type": "number",
          "default": 85,
          "minimum": 1,
          "maximum": 100,
          "description": "Reviewer 评分流程的通过分数。Harness Runner 按“工作区覆盖优先、否则回退到 User 全局设置”的顺序读取该值。"
        },
        "harness-runner.maxAutoRefactorRounds": {
          "type": "number",
          "default": 2,
          "minimum": 0,
          "description": "Reviewer 评分未通过时允许自动修复的最大轮数。Harness Runner 按“工作区覆盖优先、否则回退到 User 全局设置”的顺序读取该值。"
        },
        "harness-runner.language": {
          "type": "string",
          "default": "Chinese",
          "enum": ["Chinese", "English"],
          "enumDescriptions": [
            "插件运行时操作文案使用中文，并在初始化项目约束时生成中文 Git 提交规则。",
            "Plugin runtime UI uses English, and project-constraint initialization generates English Git commit rules."
          ],
          "description": "切换 Harness Runner 的运行时语言。修改后若要更新项目约束中的语言相关规则，需要重新初始化项目约束。"
        },
        "harness-runner.rootMenuOrder": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["planning", "constraints", "execution", "settings"]
          },
          "default": ["planning", "constraints", "execution", "settings"],
          "markdownDescription": "自定义一级菜单顺序。可用值依次为 `planning`、`constraints`、`execution`、`settings`；缺失或重复值会在运行时自动回退到默认顺序。"
        }
      }
    }
  },
  
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "package:vsix": "npx @vscode/vsce package",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.54.0",
    "eslint": "^9.39.2",
    "esbuild": "^0.27.2",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  },
  "icon": "images/harness_runner.ico"
}
