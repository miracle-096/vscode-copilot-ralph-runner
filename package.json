{
  "name": "harness-runner",
  "displayName": "Harness Runner",
  "description": "Autonomous task runner — reads prd.json user stories, tracks progress inline, and drives Cline to execute each story in an auditable execution loop",
  "version": "0.0.9",
  "publisher": "recent-graduates",
  "repository": {
    "type": "git",
    "url": "https://github.com/anushibinj/vscode-copilot-ralph-runner.git"
  },
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "harness-runner.showGuide",
        "title": "%command.showGuide.title%"
      },
      {
        "command": "harness-runner.configurePolicyGates",
        "title": "%command.configurePolicyGates.title%"
      },
      {
        "command": "harness-runner.start",
        "title": "%command.start.title%"
      },
      {
        "command": "harness-runner.rerunFailedStory",
        "title": "%command.rerunFailedStory.title%"
      },
      {
        "command": "harness-runner.stop",
        "title": "%command.stop.title%"
      },
      {
        "command": "harness-runner.status",
        "title": "%command.status.title%"
      },
      {
        "command": "harness-runner.reviewStoryApproval",
        "title": "%command.reviewStoryApproval.title%"
      },
      {
        "command": "harness-runner.resetStep",
        "title": "%command.resetStep.title%"
      },
      {
        "command": "harness-runner.initProjectConstraints",
        "title": "%command.initProjectConstraints.title%"
      },
      {
        "command": "harness-runner.refreshSourceContextIndex",
        "title": "%command.refreshSourceContextIndex.title%"
      },
      {
        "command": "harness-runner.previewSourceContextRecall",
        "title": "%command.previewSourceContextRecall.title%"
      },
      {
        "command": "harness-runner.generateAgentMap",
        "title": "%command.generateAgentMap.title%"
      },
      {
        "command": "harness-runner.recordDesignContext",
        "title": "%command.recordDesignContext.title%"
      },
      {
        "command": "harness-runner.openSettings",
        "title": "%command.openSettings.title%"
      },
      {
        "command": "harness-runner.customizeMenuOrder",
        "title": "%command.customizeMenuOrder.title%"
      },
      {
        "command": "harness-runner.showMenu",
        "title": "%command.showMenu.title%"
      },
      {
        "command": "harness-runner.quickStart",
        "title": "%command.quickStart.title%"
      },
      {
        "command": "harness-runner.appendUserStories",
        "title": "%command.appendUserStories.title%"
      }
    ],
    "keybindings": [
      {
        "command": "harness-runner.showMenu",
        "key": "alt+r"
      }
    ],
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "harness-runner.maxAutonomousLoops": {
          "type": "number",
          "default": 2,
          "minimum": 1,
          "description": "%configuration.maxAutonomousLoops.description%"
        },
        "harness-runner.loopDelayMs": {
          "type": "number",
          "default": 3000,
          "minimum": 0,
          "description": "%configuration.loopDelayMs.description%"
        },
        "harness-runner.executionResponsePollMs": {
          "type": "number",
          "default": 5000,
          "minimum": 1000,
          "description": "%configuration.executionResponsePollMs.description%"
        },
        "harness-runner.executionTimeoutMs": {
          "type": "number",
          "default": 3600000,
          "minimum": 30000,
          "description": "%configuration.executionTimeoutMs.description%"
        },
        "harness-runner.executionMinWaitMs": {
          "type": "number",
          "default": 15000,
          "minimum": 0,
          "description": "%configuration.executionMinWaitMs.description%"
        },
        "harness-runner.autoInjectProjectConstraints": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.autoInjectProjectConstraints.description%"
        },
        "harness-runner.autoInjectDesignContext": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.autoInjectDesignContext.description%"
        },
        "harness-runner.autoRecallTaskMemory": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.autoRecallTaskMemory.description%"
        },
        "harness-runner.autoCommitGit": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.autoCommitGit.description%"
        },
        "harness-runner.recalledTaskMemoryLimit": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "maximum": 10,
          "description": "%configuration.recalledTaskMemoryLimit.description%"
        },
        "harness-runner.policyGates": {
          "type": "object",
          "default": {
            "enabled": false,
            "preflightRules": [
              {
                "id": "require-project-constraints",
                "title": "Require project rules before start",
                "phase": "preflight",
                "type": "required-artifact",
                "artifact": "project-constraints",
                "enabled": false,
                "when": "always"
              },
              {
                "id": "require-design-context",
                "title": "Require design notes for UI-sensitive stories",
                "phase": "preflight",
                "type": "required-artifact",
                "artifact": "design-context",
                "enabled": false,
                "when": "story.designSensitive"
              }
            ],
            "completionRules": [
              {
                "id": "protect-dangerous-paths",
                "title": "Block risky file changes",
                "phase": "completion",
                "type": "restricted-paths",
                "paths": [
                  "prd.json",
                  ".prd/**",
                  "dist/**",
                  "build/**",
                  "out/**",
                  "coverage/**",
                  "node_modules/**",
                  ".next/**",
                  ".nuxt/**"
                ],
                "enabled": true,
                "when": "always"
              },
              {
                "id": "require-relevant-tests",
                "title": "Require at least one relevant test",
                "phase": "completion",
                "type": "require-command",
                "commandsFrom": "projectConstraints.testCommands",
                "minSuccesses": 1,
                "filePatterns": [
                  "src/**",
                  "package.json",
                  "eslint.config.*",
                  "tsconfig.json"
                ],
                "enabled": false,
                "when": "always"
              },
              {
                "id": "require-fresh-knowledge",
                "title": "Require fresh knowledge coverage before completion",
                "phase": "completion",
                "type": "knowledge-check",
                "failOnSeverities": [
                  "warning"
                ],
                "enabled": false,
                "when": "always"
              },
              {
                "id": "require-task-memory-artifact",
                "title": "Require task memory before completion",
                "phase": "completion",
                "type": "required-artifact",
                "artifact": "task-memory",
                "enabled": true,
                "when": "always"
              },
              {
                "id": "require-execution-checkpoint-artifact",
                "title": "Require execution checkpoint before completion",
                "phase": "completion",
                "type": "required-artifact",
                "artifact": "execution-checkpoint",
                "enabled": true,
                "when": "always"
              },
              {
                "id": "require-story-evidence-artifact",
                "title": "Require story evidence before completion",
                "phase": "completion",
                "type": "required-artifact",
                "artifact": "story-evidence",
                "enabled": true,
                "when": "always"
              }
            ]
          },
          "markdownDescription": "%configuration.policyGates.markdownDescription%"
        },
        "harness-runner.policyGateCommandTimeoutMs": {
          "type": "number",
          "default": 600000,
          "minimum": 1000,
          "description": "%configuration.policyGateCommandTimeoutMs.description%"
        },
        "harness-runner.approvalPromptMode": {
          "type": "string",
          "default": "default",
          "enum": ["default", "bypass", "autopilot"],
          "enumDescriptions": [
            "%configuration.approvalPromptMode.enum.default%",
            "%configuration.approvalPromptMode.enum.bypass%",
            "%configuration.approvalPromptMode.enum.autopilot%"
          ],
          "description": "%configuration.approvalPromptMode.description%"
        },
        "harness-runner.enableReviewerLoop": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.enableReviewerLoop.description%"
        },
        "harness-runner.reviewPassingScore": {
          "type": "number",
          "default": 85,
          "minimum": 1,
          "maximum": 100,
          "description": "%configuration.reviewPassingScore.description%"
        },
        "harness-runner.maxAutoRefactorRounds": {
          "type": "number",
          "default": 2,
          "minimum": 0,
          "description": "%configuration.maxAutoRefactorRounds.description%"
        },
        "harness-runner.language": {
          "type": "string",
          "default": "Chinese",
          "enum": ["Chinese", "English"],
          "enumDescriptions": [
            "%configuration.language.enum.chinese%",
            "%configuration.language.enum.english%"
          ],
          "description": "%configuration.language.description%"
        },
        "harness-runner.rootMenuOrder": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["quickStart", "appendUserStories", "guides", "constraints", "execution", "settings"]
          },
          "default": ["quickStart", "appendUserStories", "guides", "constraints", "execution", "settings"],
          "markdownDescription": "%configuration.rootMenuOrder.markdownDescription%"
        }
      }
    }
  },
  
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "package:vsix": "npx @vscode/vsce package",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.54.0",
    "eslint": "^9.39.2",
    "esbuild": "^0.27.2",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  },
  "icon": "images/harness_runner.ico"
}
