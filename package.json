{
  "name": "ralph-runner",
  "displayName": "Ralph Runner",
  "description": "Autonomous task runner — reads prd.json user stories, tracks progress inline, and drives Copilot Chat to execute each story in an automated loop",
  "version": "0.0.7",
  "publisher": "recent-graduates",
  "repository": {
    "type": "git",
    "url": "https://github.com/anushibinj/vscode-copilot-ralph-runner.git"
  },
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onChatParticipant:recent-graduates.ralph-runner"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ralph-runner.start",
        "title": "RALPH: 开始执行"
      },
      {
        "command": "ralph-runner.stop",
        "title": "RALPH: 停止执行"
      },
      {
        "command": "ralph-runner.status",
        "title": "RALPH: 查看状态"
      },
      {
        "command": "ralph-runner.reviewStoryApproval",
        "title": "RALPH: 审批高风险故事"
      },
      {
        "command": "ralph-runner.resetStep",
        "title": "RALPH: 重置故事"
      },
      {
        "command": "ralph-runner.initProjectConstraints",
        "title": "RALPH: 初始化项目约束"
      },
      {
        "command": "ralph-runner.refreshSourceContextIndex",
        "title": "RALPH: 刷新源码上下文索引"
      },
      {
        "command": "ralph-runner.previewSourceContextRecall",
        "title": "RALPH: 预览故事源上下文"
      },
      {
        "command": "ralph-runner.recordDesignContext",
        "title": "RALPH: 界面设计描述"
      },
      {
        "command": "ralph-runner.openSettings",
        "title": "RALPH: 打开设置"
      },
      {
        "command": "ralph-runner.showMenu",
        "title": "RALPH: 显示菜单"
      },
      {
        "command": "ralph-runner.quickStart",
        "title": "RALPH: 生成 PRD"
      },
      {
        "command": "ralph-runner.appendUserStories",
        "title": "RALPH: 追加用户故事"
      }
    ],
    "chatParticipants": [
      {
        "id": "recent-graduates.ralph-runner",
        "name": "ralph",
        "fullName": "RALPH Runner",
        "description": "Refine a change request against RALPH project constraints, then auto-send the final prompt to Copilot Chat.",
        "isSticky": true,
        "commands": [
          {
            "name": "ralph-spec",
            "description": "Polish a request with the merged RALPH project constraints, then auto-send the ready-to-use final version to Copilot Chat."
          }
        ]
      }
    ],
    "configuration": {
      "title": "RALPH Runner",
      "properties": {
        "ralph-runner.maxAutonomousLoops": {
          "type": "number",
          "default": 2,
          "minimum": 1,
          "description": "每次运行在暂停前最多连续执行的故事数量。"
        },
        "ralph-runner.loopDelayMs": {
          "type": "number",
          "default": 3000,
          "minimum": 0,
          "description": "每轮执行之间的等待时间，单位为毫秒。"
        },
        "ralph-runner.copilotResponsePollMs": {
          "type": "number",
          "default": 5000,
          "minimum": 1000,
          "description": "轮询 Copilot 是否空闲的间隔时间，单位为毫秒。"
        },
        "ralph-runner.copilotTimeoutMs": {
          "type": "number",
          "default": 3600000,
          "minimum": 30000,
          "description": "每个故事等待 Copilot 完成的最长时间，单位为毫秒，默认 1 小时。"
        },
        "ralph-runner.copilotMinWaitMs": {
          "type": "number",
          "default": 15000,
          "minimum": 0,
          "description": "开始检查故事是否完成前，至少等待 Copilot 开始工作的时间，单位为毫秒。"
        },
        "ralph-runner.autoInjectProjectConstraints": {
          "type": "boolean",
          "default": true,
          "description": "启用后，在构建任务提示词时自动注入已初始化的项目约束。"
        },
        "ralph-runner.requireProjectConstraintsBeforeRun": {
          "type": "boolean",
          "default": false,
          "description": "启用后，必须先初始化项目约束，RALPH 才能开始执行故事。"
        },
        "ralph-runner.autoInjectDesignContext": {
          "type": "boolean",
          "default": true,
          "description": "启用后，在构建任务提示词时自动注入已记录的界面设计描述。"
        },
        "ralph-runner.autoRecallTaskMemory": {
          "type": "boolean",
          "default": true,
          "description": "启用后，在执行故事前自动回忆相关任务记忆，并注入有限长度的既往工作上下文。"
        },
        "ralph-runner.autoCommitGit": {
          "type": "boolean",
          "default": true,
          "description": "启用后，若工作区检测到 Git 仓库，RALPH 会在执行单个用户故事时要求 Copilot 直接完成对应的 Git 提交，而不是额外生成单独的 Git 提交故事。"
        },
        "ralph-runner.recalledTaskMemoryLimit": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "maximum": 10,
          "description": "每个故事最多注入或预览的相关任务记忆条目数量。"
        },
        "ralph-runner.requireDesignContextForTaggedStories": {
          "type": "boolean",
          "default": false,
          "description": "启用后，被识别为设计敏感的故事必须先补充界面设计描述才可执行。"
        },
        "ralph-runner.policyGates": {
          "type": "object",
          "default": {
            "enabled": false,
            "preflightRules": [
              {
                "id": "require-project-constraints",
                "title": "Require project constraints before execution",
                "phase": "preflight",
                "type": "required-artifact",
                "artifact": "project-constraints",
                "enabled": false,
                "when": "always"
              },
              {
                "id": "require-design-context",
                "title": "Require design context for design-sensitive stories",
                "phase": "preflight",
                "type": "required-artifact",
                "artifact": "design-context",
                "enabled": false,
                "when": "story.designSensitive"
              }
            ],
            "completionRules": [
              {
                "id": "protect-dangerous-paths",
                "title": "Block dangerous path edits",
                "phase": "completion",
                "type": "restricted-paths",
                "paths": [
                  "prd.json",
                  ".prd/**",
                  "dist/**",
                  "build/**",
                  "out/**",
                  "coverage/**",
                  "node_modules/**",
                  ".next/**",
                  ".nuxt/**"
                ],
                "enabled": true,
                "when": "always"
              },
              {
                "id": "require-relevant-tests",
                "title": "Require at least one relevant test command",
                "phase": "completion",
                "type": "require-command",
                "commandsFrom": "projectConstraints.testCommands",
                "minSuccesses": 1,
                "filePatterns": [
                  "src/**",
                  "package.json",
                  "eslint.config.*",
                  "tsconfig.json"
                ],
                "enabled": false,
                "when": "always"
              },
              {
                "id": "require-task-memory-artifact",
                "title": "Require task memory artifact before completion",
                "phase": "completion",
                "type": "required-artifact",
                "artifact": "task-memory",
                "enabled": true,
                "when": "always"
              },
              {
                "id": "require-execution-checkpoint-artifact",
                "title": "Require execution checkpoint before completion",
                "phase": "completion",
                "type": "required-artifact",
                "artifact": "execution-checkpoint",
                "enabled": true,
                "when": "always"
              },
              {
                "id": "require-story-evidence-artifact",
                "title": "Require story evidence artifact before completion",
                "phase": "completion",
                "type": "required-artifact",
                "artifact": "story-evidence",
                "enabled": true,
                "when": "always"
              }
            ]
          },
          "markdownDescription": "机器可执行的策略门禁配置。开启后，RALPH 会在故事开始前和完成前执行 schema 中定义的 preflight/completion 规则；同时会自然并入 `requireProjectConstraintsBeforeRun` 与 `requireDesignContextForTaggedStories` 兼容规则。"
        },
        "ralph-runner.policyGateCommandTimeoutMs": {
          "type": "number",
          "default": 600000,
          "minimum": 1000,
          "description": "机器策略门禁执行测试或构建命令时的超时时间，单位为毫秒。"
        },
        "ralph-runner.language": {
          "type": "string",
          "default": "Chinese",
          "enum": ["Chinese", "English"],
          "enumDescriptions": [
            "插件运行时操作文案使用中文，并在初始化项目约束时生成中文 Git 提交规则。",
            "Plugin runtime UI uses English, and project-constraint initialization generates English Git commit rules."
          ],
          "description": "切换 Ralph Runner 的运行时语言。修改后若要更新项目约束中的语言相关规则，需要重新初始化项目约束。"
        }
      }
    }
  },
  
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "package:vsix": "npx @vscode/vsce package",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.54.0",
    "eslint": "^9.39.2",
    "esbuild": "^0.27.2",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  },
  "icon": "images/ralph_runner.ico"
}
